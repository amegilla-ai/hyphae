# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

archive/

# Obsidian workspace state (rewrites on every pane/tab change - diff noise)
.obsidian/workspace.json
vault/.obsidian/workspace.json

# Obsidian community plugin binaries - users install their own
.obsidian/plugins/
vault/.obsidian/plugins/

# Deployed agent runtime in dummy vault - generated by sync-agent.sh
# from the canonical copies in agent/. Don't track the sync artefact.
vault/_hyphae/agent/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.env

.claude/settings.local.json

# Vault path pointer - written by init_vault on first run, points at the
# user's data folder. Local to each clone.
.hyphae-vault
